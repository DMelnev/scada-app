<Window x:Class="ScadaApp.Views.VisualizationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Настройки 3D-визуализации" Height="480" Width="650"
        Background="#FF1E1E2E" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBox" x:Key="FieldStyle">
            <Setter Property="Background" Value="#FF313244"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
        </Style>
        <Style TargetType="Label" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#FF89DCEB"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="Button" x:Key="BtnStyle">
            <Setter Property="Background" Value="#FF313244"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Style="{StaticResource BtnStyle}" Content="Сохранить" Background="#FF1E6340"
                    IsDefault="True" Click="SaveClick"/>
            <Button Style="{StaticResource BtnStyle}" Content="Отмена" IsCancel="True" Click="CancelClick"/>
        </StackPanel>

        <DockPanel>
            <!-- Поля настроек -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <CheckBox Content="Включить 3D-визуализацию" Foreground="#FFCDD6F4"
                          IsChecked="{Binding Enabled}" Margin="0,0,0,8"/>
                <Label Style="{StaticResource LabelStyle}" Content="URL сервиса (WebSocket)"/>
                <TextBox Style="{StaticResource FieldStyle}" Text="{Binding ServiceUrl, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- Кнопки маппинга -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                <Button Style="{StaticResource BtnStyle}" Content="+ Добавить" Command="{Binding AddMappingCommand}"/>
                <Button Style="{StaticResource BtnStyle}" Content="✕ Удалить" Command="{Binding RemoveMappingCommand}"/>
            </StackPanel>

            <!-- Таблица маппинга -->
            <DataGrid Background="#FF181825" Foreground="#FFCDD6F4"
                      BorderBrush="#FF45475A"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#FF313244"
                      RowBackground="#FF181825" AlternatingRowBackground="#FF1E1E2E"
                      ItemsSource="{Binding Mappings}"
                      SelectedItem="{Binding SelectedMapping}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FF313244"/>
                        <Setter Property="Foreground" Value="#FF89DCEB"/>
                        <Setter Property="Padding" Value="8,4"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Тег" Binding="{Binding TagName}" Width="180"/>
                    <DataGridTextColumn Header="Объект" Binding="{Binding ObjectName}" Width="160"/>
                    <DataGridTextColumn Header="Свойство" Binding="{Binding Property}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Window>
