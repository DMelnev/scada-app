<Window x:Class="ScadaApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ScadaApp.ViewModels"
        mc:Ignorable="d"
        Title="SCADA Приложение"
        Height="700" Width="1100"
        Background="#FF1E1E2E">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ToolbarButton">
            <Setter Property="Background" Value="#FF313244"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="DataGrid" x:Key="ModernGrid">
            <Setter Property="Background" Value="#FF181825"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FF313244"/>
            <Setter Property="RowBackground" Value="#FF181825"/>
            <Setter Property="AlternatingRowBackground" Value="#FF1E1E2E"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FF313244"/>
                        <Setter Property="Foreground" Value="#FF89DCEB"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="200"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <Border Grid.Row="0" Background="#FF313244" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ToolbarButton}"
                        Command="{Binding OpenDeviceSettingsCommand}"
                        Content="⚙ Устройства"/>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="{Binding OpenTagSettingsCommand}"
                        Content="🏷 Теги"/>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="{Binding OpenDatabaseSettingsCommand}"
                        Content="🗄 База данных"/>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="{Binding OpenVisualizationSettingsCommand}"
                        Content="🎲 3D визуализация"/>
                <Separator Background="#FF45475A" Margin="8,2" Width="1"/>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="{Binding StartPollingCommand}"
                        Content="▶ Старт"
                        Background="#FF1E6340"/>
                <Button Style="{StaticResource ToolbarButton}"
                        Command="{Binding StopPollingCommand}"
                        Content="⏹ Стоп"
                        Background="#FF6E1E1E"/>
            </StackPanel>
        </Border>

        <!-- Таблица тегов -->
        <DataGrid Grid.Row="1"
                  Style="{StaticResource ModernGrid}"
                  ItemsSource="{Binding Tags}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="6,6,6,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Устройство" Binding="{Binding DeviceName}" Width="150"/>
                <DataGridTextColumn Header="Тег" Binding="{Binding TagName}" Width="180"/>
                <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="130"/>
                <DataGridTextColumn Header="Качество" Binding="{Binding Quality}" Width="90"/>
                <DataGridTextColumn Header="Последнее обновление" Binding="{Binding LastUpdate, StringFormat={}{0:HH:mm:ss.fff}}" Width="180"/>
                <DataGridCheckBoxColumn Header="Подключено" Binding="{Binding IsConnected}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Разделитель -->
        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#FF45475A"/>

        <!-- Панель лога -->
        <Border Grid.Row="3" Background="#FF11111B" Margin="6,0,6,0" BorderBrush="#FF45475A" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#FF1E1E2E" Padding="6,2">
                    <TextBlock Text="Журнал событий" Foreground="#FF89DCEB" FontWeight="SemiBold" FontSize="11"/>
                </Border>
                <DataGrid Grid.Row="1"
                          Style="{StaticResource ModernGrid}"
                          ItemsSource="{Binding LogEntries}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          FontSize="11"
                          ScrollViewer.CanContentScroll="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Время" Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Width="80"/>
                        <DataGridTextColumn Header="Уровень" Binding="{Binding Level}" Width="80"/>
                        <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Статусбар -->
        <StatusBar Grid.Row="4" Background="#FF313244" Foreground="#FFCDD6F4" FontSize="11">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator Background="#FF45475A"/>
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Text>
                        <Binding Path="IsPolling" StringFormat="Опрос активен: {0}"/>
                    </TextBlock.Text>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
