<Window x:Class="ScadaApp.Views.DatabaseSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Настройки базы данных" Height="360" Width="500"
        Background="#FF1E1E2E" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBox" x:Key="FieldStyle">
            <Setter Property="Background" Value="#FF313244"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
        </Style>
        <Style TargetType="Label" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#FF89DCEB"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="Button" x:Key="BtnStyle">
            <Setter Property="Background" Value="#FF313244"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Style="{StaticResource BtnStyle}" Content="Сохранить" Background="#FF1E6340"
                    IsDefault="True" Click="SaveClick"/>
            <Button Style="{StaticResource BtnStyle}" Content="Отмена" IsCancel="True" Click="CancelClick"/>
        </StackPanel>

        <StackPanel>
            <CheckBox Content="Включить запись в БД" Foreground="#FFCDD6F4"
                      IsChecked="{Binding Enabled}" Margin="0,0,0,10"/>

            <Label Style="{StaticResource LabelStyle}" Content="Тип базы данных"/>
            <ComboBox Background="#FF313244" Foreground="#FFCDD6F4"
                      Margin="0,2,0,8"
                      ItemsSource="{Binding DatabaseTypes}"
                      SelectedItem="{Binding DatabaseType}"/>

            <Label Style="{StaticResource LabelStyle}" Content="Строка подключения"/>
            <TextBox Style="{StaticResource FieldStyle}" Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Style="{StaticResource LabelStyle}" Content="Интервал сохранения (мс)"/>
            <TextBox Style="{StaticResource FieldStyle}" Text="{Binding SaveIntervalMs, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Style="{StaticResource LabelStyle}" Content="Размер буфера (записей)"/>
            <TextBox Style="{StaticResource FieldStyle}" Text="{Binding BufferSize, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Style="{StaticResource BtnStyle}" Content="Проверить подключение"
                    Command="{Binding TestConnectionCommand}" HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding TestConnectionResult}" Foreground="#FFA6E3A1" Margin="0,4,0,0"/>
        </StackPanel>
    </DockPanel>
</Window>
