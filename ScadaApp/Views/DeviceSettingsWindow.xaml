<Window x:Class="ScadaApp.Views.DeviceSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Настройка устройств" Height="500" Width="760"
        Background="#FF1E1E2E" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBox" x:Key="FieldStyle">
            <Setter Property="Background" Value="#FF313244"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,2,0,6"/>
        </Style>
        <Style TargetType="Label" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#FF89DCEB"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>
        <Style TargetType="Button" x:Key="BtnStyle">
            <Setter Property="Background" Value="#FF313244"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Список устройств -->
        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                <Button Style="{StaticResource BtnStyle}" Content="+ Добавить"
                        Command="{Binding AddDeviceCommand}"/>
                <Button Style="{StaticResource BtnStyle}" Content="✕ Удалить"
                        Command="{Binding RemoveDeviceCommand}"/>
            </StackPanel>
            <Border BorderBrush="#FF45475A" BorderThickness="1">
                <ListBox Background="#FF181825" Foreground="#FFCDD6F4"
                         ItemsSource="{Binding Devices}"
                         SelectedItem="{Binding SelectedDevice}"
                         DisplayMemberPath="Name"/>
            </Border>
        </DockPanel>

        <!-- Форма редактирования -->
        <Grid Grid.Column="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel DataContext="{Binding SelectedDevice}">
                    <Label Style="{StaticResource LabelStyle}" Content="Имя устройства"/>
                    <TextBox Style="{StaticResource FieldStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Style="{StaticResource LabelStyle}" Content="Тип драйвера"/>
                    <ComboBox Background="#FF313244" Foreground="#FFCDD6F4"
                              SelectedItem="{Binding DriverType}"
                              Margin="0,2,0,6">
                        <ComboBoxItem>Siemens</ComboBoxItem>
                        <ComboBoxItem>OpcUa</ComboBoxItem>
                    </ComboBox>

                    <Label Style="{StaticResource LabelStyle}" Content="IP-адрес"/>
                    <TextBox Style="{StaticResource FieldStyle}" Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Style="{StaticResource LabelStyle}" Content="Rack"/>
                    <TextBox Style="{StaticResource FieldStyle}" Text="{Binding Rack, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Style="{StaticResource LabelStyle}" Content="Slot"/>
                    <TextBox Style="{StaticResource FieldStyle}" Text="{Binding Slot, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Style="{StaticResource LabelStyle}" Content="Порт"/>
                    <TextBox Style="{StaticResource FieldStyle}" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Style="{StaticResource LabelStyle}" Content="Тип CPU"/>
                    <ComboBox Background="#FF313244" Foreground="#FFCDD6F4"
                              SelectedItem="{Binding CpuType}"
                              Margin="0,2,0,6">
                        <ComboBoxItem>S71200</ComboBoxItem>
                        <ComboBoxItem>S71500</ComboBoxItem>
                        <ComboBoxItem>S7300</ComboBoxItem>
                        <ComboBoxItem>S7400</ComboBoxItem>
                        <ComboBoxItem>S7200</ComboBoxItem>
                    </ComboBox>

                    <Label Style="{StaticResource LabelStyle}" Content="Интервал опроса (мс)"/>
                    <TextBox Style="{StaticResource FieldStyle}" Text="{Binding PollingIntervalMs, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Кнопки OK/Cancel в нижней части -->
        <StackPanel Grid.ColumnSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Orientation="Horizontal" Margin="0,6,0,0">
            <Button Style="{StaticResource BtnStyle}" Content="Сохранить"
                    Background="#FF1E6340"
                    Command="{Binding SaveCommand}"
                    IsDefault="True" Click="SaveClick"/>
            <Button Style="{StaticResource BtnStyle}" Content="Отмена"
                    Command="{Binding CancelCommand}"
                    IsCancel="True" Click="CancelClick"/>
        </StackPanel>
    </Grid>
</Window>
